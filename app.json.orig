{
  "expo": {
    "name": "AI Invoice Generator",
    "slug": "aibusinessassistant",
    "version": "1.0.0",
    "sdkVersion": "52.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A1628"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "ai.aibusinessassistant.app",
      "buildNumber": "3",
      "infoPlist": {
        "CFBundleDisplayName": "AI Invoice Generator",
        "NSMicrophoneUsageDescription": "AI Invoice Generator uses your microphone for voice input to create invoices hands-free.",
        "NSSpeechRecognitionUsageDescription": "AI Invoice Generator uses speech recognition to convert your voice to invoice details.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0A1628"
      },
      "package": "ai.aibusinessassistant.app",
      "versionCode": 3,
      "permissions": [
        "RECORD_AUDIO",
        "RECEIVE_BOOT_COMPLETED",
        "VIBRATE"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#0A1628"
        }
      ],
      "react-native-purchases"
    ],
    "extra": {
      "apiEndpoint": "https://superagent-02ccfade.base44.app/functions/aiInvoice",
      "eas": {
        "projectId": ""
      }
    },
    "owner": "bc-canadian-usa-global-ventures-llc"
  }
}